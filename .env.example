# Copy to .env for local development
# Production values go in: fly secrets set KEY=value

# Platform pollers
FLY_API_TOKEN=
RAILWAY_API_TOKEN=

# Phase 3 — Cloudflare & GitHub pollers
CF_API_TOKEN=
CF_ACCOUNT_ID=
GITHUB_TOKEN=

# Phase 3 — Anthropic usage API
ANTHROPIC_API_KEY=

# Phase 2 — agent HMAC secret (same value on hub + each machine)
RIALU_AGENT_KEY=

# DB path override (defaults to ./rialu.db locally, /data/rialu.db on Fly)
# RIALU_DB=/data/rialu.db

# MCP OAuth canonical issuer URL.
# MUST match the hostname clients connect on. Embedded into the OAuth
# Protected Resource Metadata (RFC 9728) at startup. A mismatch causes
# Claude Code to report "Failed to connect" because the cross-origin
# resource_metadata reference is refused by OAuth 2.1 discovery.
# Default is https://rialu.ie — only override if exposing a different
# canonical URL.
# RIALU_MCP_ISSUER=https://rialu.ie
