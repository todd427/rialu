#!/usr/bin/env python3
"""
rialu — CLI for Rialú.

Usage:
  rialu divergence-run [--window-days N]
                                      Compute portfolio divergence flags in-process
                                      against the shared DB (no HTTP). Default N=30.

(The key-vault commands were removed when the vault was extracted to Taisce —
taisce.irish is now the sole source of truth for secrets.)
"""

import os
import sys


# ── Commands ──────────────────────────────────────────────────────────────────

def cmd_divergence_run(window_days: int = 30):
    """Run the portfolio divergence digest in-process against the shared DB.

    Imports run_divergence() directly — no HTTP self-call — so the scheduled Fly
    machine has full app context against /data/rialu.db. db._db_path() picks the
    Fly volume automatically when FLY_APP_NAME is set.
    """
    repo_root = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
    if repo_root not in sys.path:
        sys.path.insert(0, repo_root)
    from routers.divergence import run_divergence

    summary = run_divergence(window_days=window_days)
    print(f"checked {summary['checked']} projects (window={summary['window_days']}d)")
    for flag, n in sorted(summary["flags"].items()):
        print(f"  {flag:14} {n}")
    for r in summary["results"]:
        if r["flag"] in ("stale-active", "no-trigger"):
            print(f"  ⚠ {r['project']}: {r['flag']} — {r['detail']}")


# ── Arg parsing ───────────────────────────────────────────────────────────────

def _option(args: list, *names) -> str | None:
    for n in names:
        if n in args:
            i = args.index(n)
            if i + 1 < len(args):
                val = args[i + 1]
                del args[i:i + 2]
                return val
    return None


def main():
    args = list(sys.argv[1:])

    if not args or args[0] in ("-h", "--help"):
        print(__doc__)
        sys.exit(0)

    cmd = args.pop(0)

    if cmd == "divergence-run":
        window_str = _option(args, "--window-days") or _option(args, "--window")
        window_days = int(window_str) if window_str else 30
        cmd_divergence_run(window_days=window_days)

    else:
        print(f"unknown command: {cmd}\nRun 'rialu --help' for usage.", file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    main()
